# ===== Swiftask 中转站（推荐，默认引擎）=====
SWIFTASK_API_KEY=your_swiftask_api_key_here
SWIFTASK_DEFAULT_MODEL=nano_banana_pro

# ===== Google Gemini 直连（可选）=====
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash-exp

# ===== Vertex AI 渠道（可选，默认仅按请求 channel=vertex 启用）=====
VERTEX_ENABLED=false
VERTEX_AS_DEFAULT=false
VERTEX_MODEL_NAME=gemini-3.1-flash-image-preview
# master 账号（默认兜底）
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_ADC_PATH=
# 请求未传 vertex_account 时使用；缺省回落到 master
VERTEX_DEFAULT_ACCOUNT=master
# 多账号（可选）：JSON 对象，键为账号名。支持 credentials_path（推荐）或 adc_path（兼容）：
# {"master":{"project_id":"proj-a","location":"us-central1","credentials_path":"/path/master.json"},"team2":{"project_id":"proj-b","location":"global","credentials_path":"/path/team2.json"}}
VERTEX_ACCOUNTS_JSON=
# master 示例（可直接用作起步）
# VERTEX_ACCOUNTS_JSON={"master":{"project_id":"your-gcp-project-id","location":"us-central1","credentials_path":"/path/to/master-sa.json"}}
# 或者改用文件路径（JSON 内容同上）
VERTEX_ACCOUNTS_FILE=

# ===== NewAPI 分发站（可选，设 NEWAPI_AS_DEFAULT=true 则作为默认引擎）=====
NEWAPI_API_KEY=sk-your-key
NEWAPI_BASE_URL=https://api.loveyy.qzz.io/v1
NEWAPI_DEFAULT_MODEL=gemini-3-flash
NEWAPI_REASONING_MODEL=gemini-3-flash
NEWAPI_GENERATION_MODEL=grok-imagine-1.0
NEWAPI_AS_DEFAULT=true

# ===== Venice AI（可选，原生生图 + OpenAI 兼容推理）=====
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_DEFAULT_MODEL=venice-uncensored
VENICE_GENERATION_MODEL=nano-banana-2
VENICE_AS_REASONING=false
VENICE_AS_GENERATION=true

# ===== PostgreSQL 数据库 =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stormaidb
JWT_SECRET=change-this-to-a-random-string-in-production

# ===== 通用配置 =====
MAX_IMAGE_SIZE_MB=10
MAX_RETRIES=3
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ===== 积分费率配置 =====
# 生成接口默认积分消耗（未单独配置功能费率时使用）
CREDITS_DEFAULT_GENERATION_COST=10
# 功能级费率覆盖（JSON 对象，key 为 feature_key）
# CREDITS_FEATURE_RATES_JSON={"banana-pro-edit":15,"toolbox-t2i":10}
CREDITS_FEATURE_RATES_JSON=
